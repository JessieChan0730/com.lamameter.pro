    <string name="white_balance_condition_candle_description">烛光环境整体更暖，适合餐厅、夜景室内和氛围特写。</string>
    <string name="white_balance_condition_tungsten_description">钨丝灯环境偏暖且稳定，适合家居、咖啡馆、舞台常亮灯等室内场景。</string>
